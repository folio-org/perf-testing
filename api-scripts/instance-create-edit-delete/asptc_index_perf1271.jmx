          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST_Edit instance" enabled="true">
            <stringProp name="HTTPSampler.path">/instance-storage/batch/synchronous?upsert=true</stringProp>
