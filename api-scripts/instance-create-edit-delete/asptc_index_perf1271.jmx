              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

def response = prev.getResponseDataAsString()
def json = new JsonSlurper().parseText(response)

def instances = json.instances ?: []

if (instances.isEmpty()) {
    throw new IllegalStateException(&quot;No instances found in bulk create response&quot;)
}

// Store whole created instances list for next request
vars.put(&quot;createdInstancesJson&quot;, JsonOutput.toJson(instances))

// Optional debug/count
vars.put(&quot;createdInstancesCount&quot;, instances.size().toString())

// Store first record fields if needed
vars.put(&quot;createdInstanceId_1&quot;, instances[0].id?.toString())
vars.put(&quot;createdInstanceHrid_1&quot;, instances[0].hrid?.toString())
vars.put(&quot;createdInstanceVersion_1&quot;, instances[0]._version?.toString())</stringProp>
