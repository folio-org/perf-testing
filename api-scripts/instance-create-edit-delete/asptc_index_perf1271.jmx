              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

def createdInstancesJson = vars.get(&quot;createdInstancesJson&quot;)

if (!createdInstancesJson) {
    throw new IllegalStateException(&quot;createdInstancesJson is empty. Bulk create body was not extracted.&quot;)
}

def createdInstances = new JsonSlurper().parseText(createdInstancesJson)

def updatedInstances = []

createdInstances.eachWithIndex { inst, idx -&gt;

    if (!inst.id) {
        throw new IllegalStateException(&quot;Missing id for instance index ${idx}&quot;)
    }

    def existingNotes = inst.notes ?: []

    def updatedNotes = []
    updatedNotes.addAll(existingNotes)

    updatedNotes &lt;&lt; [
        instanceNoteTypeId: &apos;1c017b8d-c783-4f63-b620-079f7a5b9c07&apos;,
        note              : &quot;bulk_edit_note_${idx + 1}&quot;,
        staffOnly         : false
    ]

    updatedInstances &lt;&lt; [
        discoverySuppress: inst.discoverySuppress == null ? false : inst.discoverySuppress,
        staffSuppress    : inst.staffSuppress == null ? false : inst.staffSuppress,
        previouslyHeld   : inst.previouslyHeld == null ? false : inst.previouslyHeld,

        id               : inst.id,
        _version         : 1,

        source           : inst.source ?: &apos;FOLIO&apos;,
        catalogedDate    : inst.catalogedDate,
        title            : inst.title,
        indexTitle       : inst.indexTitle,
        instanceTypeId   : inst.instanceTypeId,

        notes            : updatedNotes,

        contributors     : inst.contributors ?: [],
        identifiers      : inst.identifiers ?: [],
        tags             : inst.tags ?: [tagList: [&apos;jmeter&apos;]]
    ]
}

def body = [
    instances: updatedInstances
]

def jsonBody = JsonOutput.toJson(body)

vars.put(&quot;bulkEditInstancesBody&quot;, jsonBody)
vars.put(&quot;bulkEditInstancesCount&quot;, updatedInstances.size().toString())

sampler.setMethod(&apos;POST&apos;)
sampler.getArguments().removeAllArguments()
sampler.addNonEncodedArgument(&quot;&quot;, jsonBody, &quot;&quot;)
sampler.setPostBodyRaw(true)

log.info(&quot;Bulk edit instances count: &quot; + updatedInstances.size())
log.info(&quot;Bulk edit body first 1000 chars: &quot; + jsonBody.take(1000))

// Extract UUIDs from the Editing POST request body for later deletion
def editedInstanceIds = updatedInstances.collect { it.id }.findAll { it }

vars.put(&quot;deleteInstanceIdsJson&quot;, JsonOutput.toJson(editedInstanceIds))
vars.put(&quot;deleteInstanceCount&quot;, editedInstanceIds.size().toString())</stringProp>
