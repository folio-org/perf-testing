        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor folioAccessToken NEW">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import org.apache.jmeter.protocol.http.control.CookieManager
import org.apache.jmeter.protocol.http.control.Cookie
import org.apache.jmeter.protocol.http.sampler.HTTPSamplerBase
 
def this_tenant = vars.get(&quot;tenant&quot;)
def hostname = vars.get(&quot;hostname&quot;) ?: &quot;localhost&quot;
 
def sampler = ctx.getCurrentSampler()
 
if (sampler instanceof HTTPSamplerBase) {
    CookieManager cookieManager = sampler.getCookieManager()
    if (cookieManager != null) {
        Cookie cookie = new Cookie(&quot;folioAccessToken&quot;, props.get(this_tenant + &quot;MyCookie&quot;), hostname, &quot;/&quot;, false, 0)
        cookieManager.add(cookie)
    }
}
</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="TC: Create instance" enabled="true">
          <boolProp name="TransactionController.includeTimers">false</boolProp>
        </TransactionController>
        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST_Create instance" enabled="true">
            <stringProp name="HTTPSampler.path">/instance-storage/batch/synchronous?upsert=false</stringProp>
            <boolProp name="HTTPSampler.auto_redirects">true</boolProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">${bulkCreateInstancesBody}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Response Assertion" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="49587">201</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message"></stringProp>
              <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">16</intProp>
            </ResponseAssertion>
            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonOutput
import java.util.UUID
import java.util.concurrent.atomic.AtomicLong

int batchSize = (vars.get(&apos;batchSize&apos;) ?: &apos;100&apos;) as int

String counterName = &apos;perf_1271_counter&apos;
if (props.get(counterName) == null) {
    props.put(counterName, new AtomicLong(0))
}
AtomicLong counter = props.get(counterName) as AtomicLong

def instances = []

for (int i = 0; i &lt; batchSize; i++) {
    long n = counter.incrementAndGet()

    String generatedInstanceUUID = UUID.randomUUID().toString()
    String perf_1271 = UUID.randomUUID().toString()
    String title = &quot;PERF_1271_${perf_1271}&quot;

    instances &lt;&lt; [
        discoverySuppress: false,
        staffSuppress    : false,
        previouslyHeld   : false,
        source           : &apos;FOLIO&apos;,
        catalogedDate    : &apos;2025-09-02&apos;,
        title            : title,
        instanceTypeId   : &apos;6312d172-f0cf-40f6-b27d-9fa8feaf332f&apos;,
        id               : generatedInstanceUUID,
        indexTitle       : title,

        contributors     : [
            [
                name                 : &apos;JMeter Contributor&apos;,
                contributorNameTypeId: &apos;2e48e713-17f3-4c13-a9f8-23845bb210aa&apos;,
                primary              : true
            ]
        ],

        identifiers      : [
            [
                value           : &quot;cis2004162687_${n}&quot;,
                identifierTypeId: &apos;7e591197-f335-4afb-bc6d-a6d76ca3bace&apos;
            ],
            [
                value           : &quot;(amdb)4323127_${n}&quot;,
                identifierTypeId: &apos;7e591197-f335-4afb-bc6d-a6d76ca3bace&apos;
            ]
        ],

        tags             : [
            tagList: [&apos;jmeter&apos;]
        ]
    ]
}

def body = [
    instances: instances
]

vars.put(&apos;bulkCreateInstancesBody&apos;, JsonOutput.toJson(body))
</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper
import groovy.json.JsonOutput

def samplerData = prev.getSamplerData()

if (!samplerData) {
    throw new IllegalStateException(&quot;Sampler data is empty. Cannot extract bulk create POST body.&quot;)
}

def marker = &quot;POST data:&quot;
def idx = samplerData.indexOf(marker)

if (idx &lt; 0) {
    throw new IllegalStateException(&quot;Cannot find &apos;POST data:&apos; in sampler data. First 1000 chars: &quot; + samplerData.take(1000))
}

def postBody = samplerData.substring(idx + marker.length()).trim()

if (!postBody.startsWith(&quot;{&quot;)) {
    throw new IllegalStateException(&quot;Extracted POST body is not JSON. First 1000 chars: &quot; + postBody.take(1000))
}

def createBody = new JsonSlurper().parseText(postBody)
def createdInstances = createBody.instances ?: []

if (createdInstances.isEmpty()) {
    throw new IllegalStateException(&quot;No instances found in bulk create POST body.&quot;)
}

vars.put(&quot;createdInstancesJson&quot;, JsonOutput.toJson(createdInstances))
vars.put(&quot;createdInstancesCount&quot;, createdInstances.size().toString())

log.info(&quot;Saved created instances from create request body. Count: &quot; + createdInstances.size())
log.info(&quot;First created instance: &quot; + JsonOutput.toJson(createdInstances[0]))</stringProp>
            </JSR223PostProcessor>
