def this_tenant = vars.get(&quot;tenant&quot;)
def hostname = vars.get(&quot;hostname&quot;) ?: &quot;localhost&quot;
 
def sampler = ctx.getCurrentSampler()
 
if (sampler instanceof HTTPSamplerBase) {
    CookieManager cookieManager = sampler.getCookieManager()
    if (cookieManager != null) {
        Cookie cookie = new Cookie(&quot;folioAccessToken&quot;, props.get(this_tenant + &quot;MyCookie&quot;), hostname, &quot;/&quot;, false, 0)
        cookieManager.add(cookie)
    }
}
