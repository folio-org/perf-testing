                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">
def code   = prev.getResponseCode()
def body   = prev.getResponseDataAsString()
def status = vars.get(&quot;fqm_status&quot;)
def qid    = vars.get(&quot;fqmQueryId&quot;)
log.info(&quot;FQM poll: queryId=&quot; + qid + &quot;, httpCode=&quot; + code + &quot;, status=&quot; + status)

// Abort if status extraction failed (unexpected response structure)
if (status == &quot;EXTRACTION_FAILED&quot;) {
    log.error(&quot;FQM status extraction failed - unexpected response. body=&quot; + body.substring(0, Math.min(500, body.length())))
}

// Abort if stalled for more than 30 minutes
def now = System.currentTimeMillis()
if (vars.getObject(&quot;fqmPollStartTime&quot;) == null) {
    vars.putObject(&quot;fqmPollStartTime&quot;, now)
}
def elapsed = now - (vars.getObject(&quot;fqmPollStartTime&quot;) as long)
if (elapsed &gt; 3600000) {
    log.error(&quot;FQM query &quot; + qid + &quot; still IN_PROGRESS after 1 hour! Aborting.&quot;)
    ctx.getThread().stop()
}
