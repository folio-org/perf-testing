            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log EDIT progress" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">
log.info(&quot;EDIT step poll: status=${vars.get(&apos;job_status&apos;)}, progress=${vars.get(&apos;job_progress&apos;)}&quot;)
if (vars.get(&quot;job_progress&quot;) != vars.get(&quot;last_edit_progress&quot;)) {
    vars.putObject(&quot;lastUpdateTime&quot;, System.currentTimeMillis())
    vars.put(&quot;last_edit_progress&quot;, vars.get(&quot;job_progress&quot;))
}
def noUpdateMs = System.currentTimeMillis() - (vars.getObject(&quot;lastUpdateTime&quot;) ?: System.currentTimeMillis())
if (noUpdateMs &gt; 3600000) {
    log.error(&quot;EDIT step stalled for 1 hour! Aborting.&quot;)
    ctx.getThread().stop()
}
