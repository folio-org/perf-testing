              <stringProp name="script">
log.info(&quot;COMMIT step poll: status=${vars.get(&apos;job_status&apos;)}, progress=${vars.get(&apos;job_progress&apos;)}&quot;)
if (vars.get(&quot;job_progress&quot;) != vars.get(&quot;last_commit_progress&quot;)) {
    vars.putObject(&quot;lastUpdateTime&quot;, System.currentTimeMillis())
    vars.put(&quot;last_commit_progress&quot;, vars.get(&quot;job_progress&quot;))
}
def noUpdateMs = System.currentTimeMillis() - (vars.getObject(&quot;lastUpdateTime&quot;) ?: System.currentTimeMillis())
if (noUpdateMs &gt; 7200000) {
    log.error(&quot;COMMIT step stalled for 2 hours! Aborting.&quot;)
    ctx.getThread().stop()
}
