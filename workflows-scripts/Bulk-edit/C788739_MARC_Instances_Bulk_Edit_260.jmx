        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Init - Load auth from props into vars" enabled="true">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">
SampleResult.setIgnore()
def token = props.get(&quot;folioAccessToken&quot;) ?: &quot;&quot;
def userId = props.get(&quot;current_userID&quot;) ?: &quot;&quot;
vars.put(&quot;folioAccessToken&quot;, token)
vars.put(&quot;current_userID&quot;, userId)
log.info(&quot;Auth loaded: userId=&quot; + userId + &quot;, tokenLength=&quot; + token.length())
if (token.length() &lt;= 5) {
    log.error(&quot;FATAL: Invalid auth token (length=&quot; + token.length() + &quot;). Login must have failed. Stopping thread.&quot;)
    ctx.getThread().stop()
}
          </stringProp>
