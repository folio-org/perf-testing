        <hashTree>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Refresh token if 8 min elapsed" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
SampleResult.setIgnore()
def now = System.currentTimeMillis()
def lastRefresh = props.get(&quot;lastTokenRefreshTime&quot;)
if (lastRefresh == null || (now - (lastRefresh as long)) &gt;= 480000) {
    log.info(&quot;Token refresh: 8 min elapsed - re-authenticating...&quot;)
    def url = new URL(&quot;https://&quot; + vars.get(&quot;hostName&quot;) + &quot;/authn/login-with-expiry&quot;)
    def conn = (javax.net.ssl.HttpsURLConnection) url.openConnection()
    conn.setRequestMethod(&quot;POST&quot;)
    conn.setDoOutput(true)
    conn.setRequestProperty(&quot;Content-Type&quot;, &quot;application/json&quot;)
    conn.setRequestProperty(&quot;X-Okapi-Tenant&quot;, vars.get(&quot;tenant&quot;))
    conn.setConnectTimeout(30000)
    conn.setReadTimeout(30000)
    def body = &apos;{&quot;username&quot;:&quot;&apos; + vars.get(&quot;username&quot;) + &apos;&quot;,&quot;password&quot;:&quot;&apos; + vars.get(&quot;password&quot;) + &apos;&quot;}&apos;
    conn.outputStream.withWriter(&quot;UTF-8&quot;) { it.write(body) }
    def code = conn.responseCode
    if (code == 201) {
        def hdrs = conn.headerFields.findAll { k, v -&gt; k != null }.collect { k, v -&gt; k + &quot;: &quot; + v.join(&quot;,&quot;) }.join(&quot;\n&quot;)
        def matches = []
        def m = hdrs =~ /(?i)folioAccessToken=([^;,\r\n]+)/
        while (m.find()) { matches &lt;&lt; m.group(1).trim() }
        def token = matches ? matches.max { it.length() } : &quot;&quot;
        if (token &amp;&amp; token.length() &gt; 5) {
            vars.put(&quot;folioAccessToken&quot;, token)
            props.put(&quot;folioAccessToken&quot;, token)
            props.put(&quot;lastTokenRefreshTime&quot;, now)
            log.info(&quot;Token refreshed successfully. length=&quot; + token.length())
        } else {
            log.error(&quot;Token refresh: could not extract folioAccessToken from response headers&quot;)
        }
    } else {
        log.error(&quot;Token refresh failed! HTTP &quot; + code)
    }
    conn.disconnect()
}
            </stringProp>
          </JSR223Sampler>
