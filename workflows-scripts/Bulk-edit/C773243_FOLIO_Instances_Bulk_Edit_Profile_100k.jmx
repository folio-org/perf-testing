            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract matchedNumOfRecords" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">matchedNumOfRecords</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.matchedNumOfRecords</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">0</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Log retrieval progress" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">
def status = vars.get(&quot;job_status&quot;)
def progress = vars.get(&quot;job_progress&quot;)
def matched = vars.get(&quot;matchedNumOfRecords&quot;)
log.info(&quot;RETRIEVING poll: status=${status}, processed=${progress}, matched=${matched}&quot;)

// Track update time to detect stalls
if (progress != vars.get(&quot;last_progress&quot;)) {
    vars.putObject(&quot;lastUpdateTime&quot;, System.currentTimeMillis())
    vars.put(&quot;last_progress&quot;, progress)
}
// Check for stall &gt; 1 hour
def noUpdateMs = System.currentTimeMillis() - (vars.getObject(&quot;lastUpdateTime&quot;) ?: System.currentTimeMillis())
if (noUpdateMs &gt; 3600000) {
    log.error(&quot;Job ${vars.get(&apos;jobId&apos;)} has not progressed for 1 hour! Aborting.&quot;)
    ctx.getThread().stop()
}
              </stringProp>
