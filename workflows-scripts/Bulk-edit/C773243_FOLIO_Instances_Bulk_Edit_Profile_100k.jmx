        <hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST /bulk-operations/${jobId}/content-update - Apply FOLIO Instance rules" enabled="true">
            <stringProp name="TestPlan.comments">Steps 3-4: Profile selection is replaced by hardcoded rules — Admin note CHANGE_NOTE_TYPE to Action note; Staff suppress SET_TO_FALSE; Statistical code ADD_TO_EXISTING; General note ADD_TO_EXISTING</stringProp>
            <stringProp name="HTTPSampler.path">/bulk-operations/${jobId}/content-update</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">${content_update_body}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Build content-update body for FOLIO Instance rules (hardcoded)" enabled="true">
              <stringProp name="scriptLanguage">groovy</stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="script">
def jobId = vars.get(&quot;jobId&quot;)

// NOTE: Replace the UUID placeholders below with actual values from your environment:
//   actionNoteTypeId   - UUID of the &quot;Action note&quot; instance note type  (GET /instance-note-types)
//   statisticalCodeId  - UUID of the statistical code to add            (GET /statistical-codes)
//   generalNoteTypeId  - UUID of the &quot;General note&quot; instance note type  (GET /instance-note-types)
def actionNoteTypeId  = &quot;ACTION_NOTE_TYPE_UUID_PLACEHOLDER&quot;
def statisticalCodeId = &quot;STATISTICAL_CODE_UUID_PLACEHOLDER&quot;
def generalNoteTypeId = &quot;GENERAL_NOTE_TYPE_UUID_PLACEHOLDER&quot;

def body = &quot;{\&quot;bulkOperationRules\&quot;:[&quot; +
    // Rule 1: Administrative note → Change note type to Action note
    &quot;{\&quot;bulkOperationId\&quot;:\&quot;&quot; + jobId + &quot;\&quot;,\&quot;rule_details\&quot;:{\&quot;option\&quot;:\&quot;ADMINISTRATIVE_NOTE\&quot;,\&quot;tenants\&quot;:[],\&quot;actions\&quot;:[{\&quot;type\&quot;:\&quot;CHANGE_TYPE\&quot;,\&quot;initial\&quot;:null,\&quot;updated\&quot;:\&quot;&quot; + actionNoteTypeId + &quot;\&quot;,\&quot;tenants\&quot;:[],\&quot;updated_tenants\&quot;:[],\&quot;parameters\&quot;:[]}]}},&quot; +
    // Rule 2: Staff suppress → Set false
    &quot;{\&quot;bulkOperationId\&quot;:\&quot;&quot; + jobId + &quot;\&quot;,\&quot;rule_details\&quot;:{\&quot;option\&quot;:\&quot;STAFF_SUPPRESS\&quot;,\&quot;tenants\&quot;:[],\&quot;actions\&quot;:[{\&quot;type\&quot;:\&quot;SET_TO_FALSE\&quot;,\&quot;initial\&quot;:null,\&quot;updated\&quot;:null,\&quot;tenants\&quot;:[],\&quot;updated_tenants\&quot;:[],\&quot;parameters\&quot;:[]}]}},&quot; +
    // Rule 3: Statistical code → Add
    &quot;{\&quot;bulkOperationId\&quot;:\&quot;&quot; + jobId + &quot;\&quot;,\&quot;rule_details\&quot;:{\&quot;option\&quot;:\&quot;STATISTICAL_CODE\&quot;,\&quot;tenants\&quot;:[],\&quot;actions\&quot;:[{\&quot;type\&quot;:\&quot;ADD_TO_EXISTING\&quot;,\&quot;initial\&quot;:null,\&quot;updated\&quot;:\&quot;&quot; + statisticalCodeId + &quot;\&quot;,\&quot;tenants\&quot;:[],\&quot;updated_tenants\&quot;:[],\&quot;parameters\&quot;:[]}]}},&quot; +
    // Rule 4: Instance note (General note) → Add note
    &quot;{\&quot;bulkOperationId\&quot;:\&quot;&quot; + jobId + &quot;\&quot;,\&quot;rule_details\&quot;:{\&quot;option\&quot;:\&quot;INSTANCE_NOTE\&quot;,\&quot;tenants\&quot;:[],\&quot;actions\&quot;:[{\&quot;type\&quot;:\&quot;ADD_TO_EXISTING\&quot;,\&quot;initial\&quot;:null,\&quot;updated\&quot;:\&quot;Bulk edit performance test note\&quot;,\&quot;tenants\&quot;:[],\&quot;updated_tenants\&quot;:[],\&quot;parameters\&quot;:[{\&quot;key\&quot;:\&quot;INSTANCE_NOTE_TYPE_ID_KEY\&quot;,\&quot;value\&quot;:\&quot;&quot; + generalNoteTypeId + &quot;\&quot;}]}]}}],&quot; +
    &quot;\&quot;totalRecords\&quot;:1}&quot;

vars.put(&quot;content_update_body&quot;, body)
log.info(&quot;content-update body: &quot; + body)
              </stringProp>
            </JSR223PreProcessor>
