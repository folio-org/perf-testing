          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Debug - Log login response headers" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
log.info(&quot;LOGIN response code: &quot; + prev.getResponseCode())
log.info(&quot;LOGIN response headers: &quot; + prev.getResponseHeaders().substring(0, Math.min(500, prev.getResponseHeaders().length())))
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Extract folioAccessToken - all occurrences, pick longest (real JWT)" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">
def headers = prev.getResponseHeaders()
log.info(&quot;=== FULL LOGIN RESPONSE HEADERS ===\n&quot; + headers)

// Find ALL folioAccessToken values (there may be &gt;1 Set-Cookie header)
def matches = []
def m = headers =~ /(?i)folioAccessToken=([^;,\r\n]+)/
while (m.find()) {
    def val = m.group(1).trim()
    if (val &amp;&amp; val != &quot;&quot;) {
        matches &lt;&lt; val
    }
}
log.info(&quot;All folioAccessToken values found: &quot; + matches)

// Pick the longest value - that is the real JWT (not a sentinel &quot;1&quot; flag)
def token = matches ? matches.max { it.length() } : &quot;&quot;

if (token &amp;&amp; token.length() &gt; 5) {
    vars.put(&quot;folioAccessToken&quot;, token)
    props.put(&quot;folioAccessToken&quot;, token)
    log.info(&quot;Token stored in props. length=&quot; + token.length() + &quot;, first30=&quot; + token.substring(0, Math.min(30, token.length())))
} else {
    // Fallback: try X-Okapi-Token header
    def okapiMatcher = headers =~ /(?i)X-Okapi-Token:\s*([^\r\n]+)/
    if (okapiMatcher.find()) {
        def okapiToken = okapiMatcher.group(1).trim()
        vars.put(&quot;folioAccessToken&quot;, okapiToken)
        props.put(&quot;folioAccessToken&quot;, okapiToken)
        log.info(&quot;Fallback: X-Okapi-Token stored. length=&quot; + okapiToken.length())
    } else {
        log.error(&quot;ERROR: Could not extract any valid auth token from login response!&quot;)
        vars.put(&quot;folioAccessToken&quot;, &quot;TOKEN_NOT_FOUND&quot;)
        props.put(&quot;folioAccessToken&quot;, &quot;TOKEN_NOT_FOUND&quot;)
    }
}
            </stringProp>
          </JSR223PostProcessor>
          <hashTree/>
