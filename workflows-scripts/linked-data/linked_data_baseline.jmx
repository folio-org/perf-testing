    &quot;accessTokenExpiration&quot;: &quot;${accessTokenGenerationTime}&quot;,&#xd;
    &quot;refreshTokenExpiration&quot;: &quot;${refreshTokenGenerationTime}&quot;&#xd;
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
