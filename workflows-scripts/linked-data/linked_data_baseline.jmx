          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">SampleResult.setIgnore()
vars.get(&apos;tenants&apos;).trim().split(&apos;-&apos;).eachWithIndex { tenants, index -&gt;
    vars.put(&apos;tenants_&apos; + ++index, tenants.trim())
