              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor Unique number " enabled="true">
                <stringProp name="scriptLanguage">groovy</stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="script">// JSR223 PreProcessor  | Language: Groovy
// Check: &quot;Cache compiled script&quot; for performance.

import java.util.concurrent.atomic.AtomicLong

// Global sequence key (shared across the whole test JVM).
// Change this key if you want an independent counter per scope.
def key   = &apos;UNIQUE_SEQ_GLOBAL&apos;
def start = 1008L

// Get or create an AtomicLong in JMeter properties (thread-safe &amp; shared)
def counter = props.get(key) as AtomicLong
if (counter == null) {
    synchronized (props) {
        counter = props.get(key) as AtomicLong
        if (counter == null) {
            counter = new AtomicLong(start - 1)  // so first increment = start
            props.put(key, counter)
        }
    }
}

// Next unique number
long next = counter.incrementAndGet()

// Expose to JMeter vars for this sampler
vars.put(&apos;uniqueNumber&apos;, Long.toString(next))
</stringProp>
              </JSR223PreProcessor>
